# Backend Environment Variables (Production)
# Set these in Cloudflare Workers dashboard or via wrangler secrets

# For production deployment, the worker URL is auto-generated
# Example: https://opengrammar.yourname.workers.dev

# Set API keys via wrangler:
#   wrangler secret put OPENAI_API_KEY
#   wrangler secret put OPENROUTER_API_KEY

# Environment: production (set via wrangler.toml environments)
# DEBUG: false (default in production)
