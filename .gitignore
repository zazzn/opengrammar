node_modules
dist
.DS_Store
*.log
.env
.env.*
!.env.example
.wrangler
.dev.vars

# Harper WASM is copied from node_modules at predev/prebuild — never commit it
opengrammar/extension/public/wasm/

# n-gram corpus download cache (regenerable; model.bin IS committed)
opengrammar/extension/.ngram-cache/

# Exploratory FP-audit + benchmark scratch corpora (regenerable; see docs/24-25)
opengrammar/extension/scripts/.fp-corpora/

# Local agent/tooling config — never publish
.claude/

# Local Netlify folder
.netlify

# Rust build output for the desktop app (regenerable; never commit — multi-GB)
desktop/target/
desktop/**/target/
# DPAPI-encrypted key / local config live in %APPDATA%, never in the repo, but
# guard against any stray copies landing under desktop/
desktop/**/apikey.bin
desktop/**/config.json
